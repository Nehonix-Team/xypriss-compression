{
  "name": "xypriss-compression",
  "version": "1.0.0",
  "description": "High-performance cross-platform Go-based compression engine for the XyPriss framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "compression",
    "gzip",
    "deflate",
    "brotli",
    "br",
    "middleware",
    "express",
    "xypriss",
    "http",
    "stream",
    "algorithm-enforcement",
    "typescript"
  ],
  "author": {
    "name": "Nehonix Team",
    "url": "https://nehonix.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nehonix-Team/xypriss-compression-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/Nehonix-Team/xypriss-compression-plugin/issues"
  },
  "homepage": "https://github.com/Nehonix-Team/xypriss-compression-plugin#readme",
  "dependencies": {
    "bytes": "^3.1.2",
    "compressible": "^2.0.18",
    "on-headers": "^1.1.0",
    "vary": "^1.1.2"
  },
  "devDependencies": {
    "@types/bytes": "^3.1.4",
    "@types/compressible": "^2.0.2",
    "@types/debug": "^4.1.12",
    "@types/node": "^20.0.0",
    "@types/on-headers": "^1.0.4",
    "@types/vary": "^1.1.3",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">= 14.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:go": "bun run scripts/build-xlibc.ts",
    "postinstall": "bun run scripts/install-xlibc.ts",
    "build": "xfpm run build:go && tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "xfpm run build"
  }
}
